# Copy this file to .env and set the path for your installation.
# .env is not committed — it stays local to your machine.
#
# CNC_REMASTERED_DATA must point to the remastered game's Data directory.
# Integration tests will FAIL (not skip) if this is not set.
#
# Steam (Linux) default:
#   CNC_REMASTERED_DATA=$HOME/.local/share/Steam/steamapps/common/CnCRemastered/Data
#
# The following MEG files must exist under this path:
#   TEXTURES_TD_SRGB.MEG   — unit/structure/infantry ZIPs with TGA frames
#   CONFIG.MEG             — tileset XML definitions (DATA\XML\TILESETS\TD_UNITS.XML etc.)

CNC_REMASTERED_DATA=/path/to/CnCRemastered/Data
